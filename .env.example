# Copy this file to `.env` and fill in your values.  NEVER commit `.env` (it is .gitignored).
#
# The document generator reads OPENAI_API_KEY1 specifically (safety-tooling copies it to OPENAI_API_KEY).
OPENAI_API_KEY1=sk-your-key-here
OPENAI_API_KEY=sk-your-key-here
#
# Path to your local clone of safety-research/false-facts (provides the `false_facts` library).
FALSE_FACTS_REPO=~/workdir/false-facts/false-facts
#
# Not needed for this project (OpenAI-only generation). Leave unset:
# ANTHROPIC_API_KEY=
# TOGETHER_API_KEY=
# HF_TOKEN=
